FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir flask waitress youtube-transcript-api yt-dlp Pillow

COPY transcript_server.py .

RUN mkdir -p /app/credentials

EXPOSE 5151

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:5151/health')" || exit 1

CMD ["python", "transcript_server.py"]
